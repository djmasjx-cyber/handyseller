DATABASE_URL="postgresql://user:YOUR_DB_PASSWORD@YOUR_HOST:6432/handyseller?sslmode=require"
JWT_SECRET="your-secret-key"
# Ключ шифрования PII (email, name, phone, токены МП). Минимум 32 символа.
# Либо ENCRYPTION_KEY (scrypt → DEK), либо ENCRYPTION_DEK_WRAPPED (DEK, обёрнутый KMS) — приоритет у DEK_WRAPPED.
# ENCRYPTION_DEK_WRAPPED="kms:w:1:..."  # см. scripts/wrap-encryption-key-for-kms.ts и docs/DEPLOY-VM.md
ENCRYPTION_KEY="min-32-chars-for-aes-256-key-change-me"
# --- Yandex KMS (опционально; envelope DEK через SymmetricCrypto) ---
# Создать ключ: yc kms symmetric-key create ...
# KMS_KEY_ID=abjxxxxxxxxxxxxxxxxxxxx
# На VM с SA обычно достаточно metadata (YC_IAM_TOKEN не нужен).
# Локально / CI: выдать IAM и экспортировать:
# YC_IAM_TOKEN=$(yc iam create-token)
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
CORS_ORIGIN="http://localhost:3000"
PORT=4000

# Admin seed (для npm run prisma:seed — или задать в .env.secrets в корне)
ADMIN_EMAIL=your-admin@example.com
ADMIN_PASSWORD=your-secure-password

# ВТБ Эквайринг (sandbox: vtb.rbsuat.com, prod: platezh.vtb24.ru)
# VTB_USER_NAME=
# VTB_PASSWORD=
# VTB_MODE=sandbox
# VTB_WEBHOOK_SECRET=  # опционально, для проверки подписи callback

# SMTP для отправки кодов подтверждения при регистрации (обязательно в production)
# Yandex Mail, Mail.ru, Gmail или любой SMTP
# SMTP_HOST=smtp.yandex.ru
# SMTP_PORT=587
# SMTP_USER=noreply@handyseller.ru
# SMTP_PASS=your-password
# EMAIL_FROM="HandySeller <noreply@handyseller.ru>"
# Без SMTP в dev: код выводится в консоль API

# AI Assistant (Yandex GPT)
# YANDEX_GPT_API_KEY=your-yandex-gpt-api-key
# YANDEX_GPT_FOLDER_ID=your-yandex-cloud-folder-id

# AI Assistant — Telegram уведомления операторам (низкая уверенность)
# TELEGRAM_BOT_TOKEN=123456:ABC...
# TELEGRAM_OPERATOR_CHAT_ID=-1001234567890  # опционально, можно задать через /start

# Monitoring
LOG_LEVEL=info
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# TELEGRAM_ALERT_BOT_TOKEN=123456:ABC...
# TELEGRAM_ALERT_CHAT_ID=-1001234567890
# Ежедневно: сводка по истекающим/истёкшим токенам маркетплейсов → тот же чат (см. security/marketplace-token-governance.yaml)
# TELEGRAM_MARKETPLACE_ALERTS=0  # отключить только алерты по МП, ошибки API идут как раньше
# MARKETPLACE_EXPIRY_CRON_DISABLED=1  # полностью отключить cron проверки сроков

# ============================================================
# Image Storage: Yandex Object Storage (S3-compatible)
# ============================================================
# Used for: product photos, user uploads
# Console: https://console.cloud.yandex.ru/ → Object Storage
#
# Setup:
# 1. Create bucket "handyseller-media" with public read access
# 2. Create service account with storage.editor role
# 3. Generate static access key for the service account
# 4. Enable CORS for: app.handyseller.ru, dev.handyseller.ru, localhost:3000
#
# Public URL format: https://storage.yandexcloud.net/{bucket}/{key}
#
S3_ENDPOINT=https://storage.yandexcloud.net
S3_REGION=ru-central1
S3_BUCKET=handyseller-media
S3_ACCESS_KEY_ID=your-access-key-id
S3_SECRET_ACCESS_KEY=your-secret-access-key
