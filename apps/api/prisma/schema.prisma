generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String   @id @default(uuid())
  email           String?  @unique // переходный период; новые пользователи — только emailHash/emailEncrypted
  emailHash       String?  @unique @map("email_hash") // HMAC для поиска при логине
  emailEncrypted  String?  @map("email_encrypted") // AES-256-GCM шифрованный email
  passwordHash    String   @map("password_hash")
  name            String? // зашифровано
  phone           String? // зашифровано
  role            Role     @default(USER)
  isActive        Boolean  @default(true) @map("is_active")
  twoFactorSecret String?  @map("two_factor_secret") @db.Text
  linkedToUserId  String?  @map("linked_to_user_id") // Привязка к другому аккаунту — использовать его маркетплейсы (Ozon, WB)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  linkedToUser      User?                   @relation("UserLink", fields: [linkedToUserId], references: [id])
  linkedAccounts    User[]                  @relation("UserLink")
  products          Product[]
  materials         Material[]
  marketplaceConns  MarketplaceConnection[]
  orders            Order[]
  salesSources      SalesSource[]
  wbSupplies        WbSupply[]
  subscription      Subscription?
  refreshTokens     RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  authAuditLogs     AuthAuditLog[]
  stockLogs         StockLog[]
  productFieldLogs  ProductFieldLog[]
  productChangeLogs ProductChangeLog[]
  payments          Payment[]
  reviews           Review[]
  organizationProfile OrganizationProfile?
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  tokenHash String   @unique @map("token_hash")
  familyId  String   @map("family_id")
  expiresAt DateTime @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  replacedByTokenHash String? @map("replaced_by_token_hash")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
  @@index([familyId])
  @@index([userId])
}

model AuthAuditLog {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  action    String
  ip        String?
  userAgent String?  @map("user_agent")
  success   Boolean
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([createdAt])
}

model LoginAttempt {
  id             String   @id @default(uuid())
  ip             String
  email          String? // переходный период
  emailHash      String?  @map("email_hash")
  emailEncrypted String?  @map("email_encrypted") // зашифрованный email
  success        Boolean
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([ip])
  @@index([emailHash])
  @@index([createdAt])
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

/// Коды подтверждения email при регистрации. TTL 15 минут.
model EmailVerification {
  id             String   @id @default(uuid())
  emailHash      String   @unique @map("email_hash") // HMAC для поиска
  code           String // 6-значный код (хранится, истекает быстро)
  passwordHash   String   @map("password_hash")
  nameEncrypted  String?  @map("name_encrypted")
  phoneEncrypted String?  @map("phone_encrypted")
  expiresAt      DateTime @map("expires_at")
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([emailHash])
  @@index([expiresAt])
}

enum Role {
  USER
  ADMIN
}

/// Реквизиты юридического лица / ИП — для выставления счетов и актов.
model OrganizationProfile {
  id              String   @id @default(uuid())
  userId          String   @unique @map("user_id")

  // Тип организации и налогообложение
  entityType      String?  @map("entity_type")   // ООО | ИП | АО | ПАО
  taxSystem       String?  @map("tax_system")     // ОСНО | УСН_ДОХОДЫ | УСН_ДОХОДЫ_РАСХОДЫ | ПСН | ЕСХН | НПД | АУСН
  vatRate         String?  @map("vat_rate")       // БЕЗ_НДС | 0 | 5 | 7 | 10 | 20

  // Идентификаторы
  inn             String?  // ИНН
  kpp             String?  // КПП (только для ООО/АО)
  ogrn            String?  // ОГРН (ООО) или ОГРНИП (ИП)
  okpo            String?  // ОКПО
  okved           String?  // Основной ОКВЭД

  // Наименования
  fullName        String?  @map("full_name")      // Полное наименование
  shortName       String?  @map("short_name")     // Сокращённое наименование

  // Адреса
  legalAddress    String?  @map("legal_address")  // Юридический адрес
  actualAddress   String?  @map("actual_address") // Фактический адрес

  // Банковские реквизиты
  bik             String?  // БИК
  bankName        String?  @map("bank_name")      // Наименование банка
  settlementAccount String? @map("settlement_account") // Расчётный счёт
  corrAccount     String?  @map("corr_account")   // Корреспондентский счёт

  // Контакты и подписанты
  orgPhone        String?  @map("org_phone")      // Телефон организации
  directorName    String?  @map("director_name")  // Генеральный директор / ИП
  chiefAccountant String?  @map("chief_accountant") // Главный бухгалтер

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("organization_profile")
}

enum ReviewStatus {
  PENDING
  PUBLISHED
  REJECTED
}

model Review {
  id           String       @id @default(uuid())
  userId       String       @map("user_id")
  text         String       @db.Text
  rating       Int          @default(5)
  status       ReviewStatus @default(PENDING)
  adminNote    String?      @map("admin_note") @db.Text
  moderatedBy  String?      @map("moderated_by")
  moderatedAt  DateTime?    @map("moderated_at")
  publishedAt  DateTime?    @map("published_at")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([userId, createdAt])
  @@map("review")
}

model Product {
  id               String    @id @default(uuid())
  displayId        Int       @unique @default(dbgenerated("nextval('product_display_id_seq'::regclass)")) @map("display_id") // Сквозной ID: 0001, 0002...
  userId           String    @map("user_id")
  title            String
  description      String?   @db.Text
  cost             Decimal   @default(0) @db.Decimal(10, 2)
  price            Decimal?  @db.Decimal(10, 2) // Ваша цена (продажная) для Ozon
  oldPrice         Decimal?  @map("old_price") @db.Decimal(10, 2) // Цена до скидки для Ozon
  imageUrl         String?   @map("image_url") // Основное фото (URL)
  imageUrls        Json?     @map("image_urls") // Доп. фото: массив URL для WB (JSON string[])
  videoUrl         String?   @map("video_url") // Видео для WB/Ozon (URL)
  sku              String?   @unique // Legacy: WB-xxx-nmId. Связка через ProductMarketplaceMapping.
  article          String? // Артикул продавца (только отображение, редактируемый)
  stock            Int       @default(0)
  seoTitle         String?   @map("seo_title") @db.VarChar(255) // SEO-заголовок
  seoKeywords      String?   @map("seo_keywords") @db.VarChar(500) // Ключевые слова через запятую
  seoDescription   String?   @map("seo_description") @db.VarChar(500) // SEO-описание
  barcodeWb        String?   @map("barcode_wb") // Штрих-код товара WB (из sizes[].skus)
  barcodeOzon      String?   @map("barcode_ozon") // Штрих-код товара Ozon
  brand            String?   @db.VarChar(200) // Бренд (обяз. на WB, vendor на Яндексе)
  weight           Int?      @map("weight") // Вес в граммах
  width            Int?      @map("width") // Ширина в мм
  length           Int?      @map("length") // Длина в мм
  height           Int?      @map("height") // Высота в мм
  productUrl       String?   @map("product_url") @db.VarChar(512) // URL страницы товара (обяз. на Яндексе)
  color            String?   @db.VarChar(100) // Цвет (WB: characteristics, Ozon: attributes, Яндекс: param)
  itemsPerPack     Int?      @map("items_per_pack") // Количество предметов в упаковке (WB, Ozon, Яндекс)
  material         String?   @db.VarChar(200) // Материал изделия
  craftType        String?   @map("craft_type") @db.VarChar(200) // Вид творчества
  countryOfOrigin  String?   @map("country_of_origin") @db.VarChar(100) // Страна производства
  packageContents  String?   @map("package_contents") @db.Text // Комплектация
  richContent      String?   @map("rich_content") @db.Text // Рич-контент (HTML): WB/Ozon/Яндекс
  ozonCategoryId   Int?      @map("ozon_category_id") // Ozon: description_category_id из справочника
  ozonTypeId       Int?      @map("ozon_type_id") // Ozon: type_id из справочника
  ozonCategoryPath String?   @map("ozon_category_path") @db.VarChar(500) // Путь для отображения: "Хобби > Материал > Бусина"
  wbSubjectId      Int?      @map("wb_subject_id") // WB: subjectId из справочника /content/v2/object/all
  wbCategoryPath   String?   @map("wb_category_path") @db.VarChar(500) // Путь WB для отображения
  wbColorId        Int?      @map("wb_color_id") // WB: color ID из справочника /content/v2/directory/colors
  wbColorName      String?   @map("wb_color_name") @db.VarChar(100) // Название цвета WB
  archivedAt       DateTime? @map("archived_at") // Архивированный — не показывается в основном списке
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  user                User                        @relation(fields: [userId], references: [id], onDelete: Cascade)
  materials           ProductMaterial[]
  orders              OrderItem[]
  stockLogs           StockLog[]
  fieldLogs           ProductFieldLog[]
  changeLogs          ProductChangeLog[]
  marketplaceMappings   ProductMarketplaceMapping[]
  commissions           ProductMarketplaceCommission[]

  @@index([userId, article])
}

/// Унифицированная история изменений товаров (триггер на Product + явные записи).
/// Ловит ВСЕ изменения — stock, поля, archive/restore.
model ProductChangeLog {
  id         String   @id @default(uuid())
  productId  String   @map("product_id")
  userId     String   @map("user_id")
  changeType String   @map("change_type")
  fieldName  String?  @map("field_name")
  oldValue   String?  @map("old_value") @db.Text
  newValue   String?  @map("new_value") @db.Text
  delta      Int?
  source     String?
  note       String?  @db.Text
  createdAt  DateTime @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([createdAt])
  @@map("product_change_log")
}

/// Связка товара с маркетплейсом по СИСТЕМНОМУ ID (не по артикулу!).
/// WB: externalSystemId = nm_id. Ozon: product_id. Amazon: ASIN.
model ProductMarketplaceMapping {
  id          String          @id @default(uuid())
  productId   String          @map("product_id")
  userId      String          @map("user_id")
  marketplace MarketplaceType

  externalSystemId String  @map("external_system_id") // nm_id (WB), product_id (Ozon), ASIN
  externalGroupId  String? @map("external_group_id") // imt_id (WB) — опционально
  externalArticle  String? @map("external_article") // vendorCode, offer_id — только для UI

  syncStock Boolean @default(true) @map("sync_stock")
  isActive  Boolean @default(true) @map("is_active")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, marketplace, externalSystemId])
  @@index([productId])
  @@index([userId, marketplace])
}

/// Комиссии и тарифы маркетплейса по схеме хранения (FBO/FBS) для конкретного товара.
/// Синхронизируется из API маркетплейсов ежедневно и по запросу.
model ProductMarketplaceCommission {
  id                  String   @id @default(uuid())
  productId           String   @map("product_id")
  marketplace         String   // 'OZON' | 'WILDBERRIES' | 'YANDEX' | ...
  scheme              String   // 'FBO' | 'FBS'
  marketplacePrice    Decimal  @default(0) @db.Decimal(10, 2) @map("marketplace_price") // цена на этом маркетплейсе (₽)
  salesCommissionPct  Decimal  @default(0) @db.Decimal(6, 2) @map("sales_commission_pct")
  salesCommissionAmt  Decimal  @default(0) @db.Decimal(10, 2) @map("sales_commission_amt")
  logisticsAmt        Decimal  @default(0) @db.Decimal(10, 2) @map("logistics_amt")
  firstMileAmt        Decimal  @default(0) @db.Decimal(10, 2) @map("first_mile_amt")
  returnAmt           Decimal  @default(0) @db.Decimal(10, 2) @map("return_amt")
  acceptanceAmt       Decimal  @default(0) @db.Decimal(10, 2) @map("acceptance_amt")
  totalFeeAmt         Decimal  @default(0) @db.Decimal(10, 2) @map("total_fee_amt")
  syncedAt            DateTime @default(now()) @map("synced_at")
  rawData             Json?    @map("raw_data")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, marketplace, scheme])
  @@index([productId])
  @@map("product_marketplace_commission")
}

model StockLog {
  id             String         @id @default(uuid())
  productId      String         @map("product_id")
  userId         String         @map("user_id")
  delta          Int // + пополнение, - списание (продажа)
  quantityBefore Int            @map("quantity_before")
  quantityAfter  Int            @map("quantity_after")
  source         StockLogSource @default(MANUAL)
  note           String?        @db.Text
  createdAt      DateTime       @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([userId])
  @@index([createdAt])
}

/// История изменений полей товара (название, цена, описание, артикул).
model ProductFieldLog {
  id        String   @id @default(uuid())
  productId String   @map("product_id")
  userId    String   @map("user_id")
  field     String // title | cost | description | article
  oldValue  String?  @map("old_value") @db.Text
  newValue  String?  @map("new_value") @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([createdAt])
  @@map("product_field_log")
}

enum StockLogSource {
  MANUAL // Ручное пополнение/списание
  SALE // Продажа на маркетплейсе
  IMPORT // Импорт с маркетплейса
  SYNC // Синхронизация
}

model Material {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  name      String
  cost      Decimal  @db.Decimal(10, 2)
  unit      String   @default("шт")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  products ProductMaterial[]
}

model ProductMaterial {
  productId  String   @map("product_id")
  materialId String   @map("material_id")
  quantity   Decimal  @db.Decimal(10, 2)
  createdAt  DateTime @default(now()) @map("created_at")

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  material Material @relation(fields: [materialId], references: [id], onDelete: Cascade)

  @@id([productId, materialId])
}

model MarketplaceConnection {
  id           String          @id @default(uuid())
  userId       String          @map("user_id")
  marketplace  MarketplaceType
  token        String?         @db.Text
  statsToken   String?         @map("stats_token") @db.Text
  refreshToken String?         @map("refresh_token") @db.Text
  sellerId     String?         @map("seller_id")
  warehouseId  String?         @map("warehouse_id")
  expiresAt    DateTime?       @map("expires_at")
  lastSyncAt   DateTime?       @map("last_sync_at")
  lastError    String?         @map("last_error") @db.Text
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum MarketplaceType {
  WILDBERRIES
  OZON
  YANDEX
  AVITO
  MANUAL
}

model Order {
  id                String          @id @default(uuid())
  userId            String          @map("user_id")
  marketplace       MarketplaceType
  externalId        String          @map("external_id")
  status            OrderStatus     @default(NEW)
  totalAmount       Decimal         @map("total_amount") @db.Decimal(10, 2)
  warehouseName     String?         @map("warehouse_name")
  rawStatus         String?         @map("raw_status")
  processingTimeMin Int?            @map("processing_time_min")
  holdUntil         DateTime?       @map("hold_until")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  /// WB: id заказа (числовой) для QR-этикетки. Не srid! API /api/v3/orders/stickers принимает orders: [id]
  wbStickerNumber   String?            @map("wb_sticker_number")
  /// Ozon: posting_number для этикетки заказа
  ozonPostingNumber String?            @map("ozon_posting_number")
  /// WB: тип фулфилмента заказа (FBS/DBS/DBW)
  wbFulfillmentType WbFulfillmentType? @map("wb_fulfillment_type")

  /// Логистика и комиссия (из API WB reportDetailByPeriod, Ozon finance/transaction/list)
  logisticsCost    Decimal?  @map("logistics_cost") @db.Decimal(10, 2)
  commissionAmount Decimal?  @map("commission_amount") @db.Decimal(10, 2)
  costsSyncedAt    DateTime? @map("costs_synced_at")

  /// Источник продажи для ручных заказов (MANUAL): "Авито", "Инстаграм" и т.д.
  salesSource String?  @map("sales_source")
  /// FBO: товар со склада маркетплейса (WB: DBW, Ozon: FBO) — не списывать остаток «Мой склад»
  isFbo       Boolean? @map("is_fbo")

  /// Классификация отмен: CANCELLATION — отмена до фактической отгрузки, REFUSAL — отказ после отгрузки.
  cancellationKind      OrderCancellationKind? @map("cancellation_kind")
  /// Ozon: отмена после отгрузки по полю cancellation.cancelled_after_ship.
  cancelledAfterShip    Boolean?               @map("cancelled_after_ship")
  /// Ozon: кто инициировал отмену (CLIENT/SELLER/OZON/SYSTEM/DELIVERY).
  cancellationInitiator String?                @map("cancellation_initiator")
  /// Ozon: тип отмены.
  cancellationType      String?                @map("cancellation_type")
  /// Ozon: причина отмены (текст).
  cancellationReason    String?                @map("cancellation_reason")
  /// Ozon: ID причины отмены.
  cancellationReasonId  BigInt?                @map("cancellation_reason_id")
  /// Полный сырой объект cancellation от маркетплейса для аудита.
  cancellationRaw       Json?                  @map("cancellation_raw")

  user           User                 @relation(fields: [userId], references: [id])
  items          OrderItem[]
  processingTime OrderProcessingTime? // источник истины для времени обработки
  statusEvents   OrderStatusEvent[]

  @@unique([userId, marketplace, externalId])
  @@index([userId, marketplace])
}

enum WbFulfillmentType {
  FBS
  DBS
  DBW
}

model OrderProcessingTime {
  id                String   @id @default(uuid())
  orderId           String   @unique @map("order_id")
  processingTimeMin Int      @map("processing_time_min")
  source            String   @default("sync_proxy") // sync_proxy | webhook | manual
  calculatedAt      DateTime @default(now()) @map("calculated_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model OrderItem {
  id        String   @id @default(uuid())
  orderId   String   @map("order_id")
  productId String   @map("product_id")
  quantity  Int
  price     Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now()) @map("created_at")

  /// Штрих-код товара WB (для печати этикетки товара)
  productBarcodeWb   String? @map("product_barcode_wb")
  /// Штрих-код товара Ozon (для печати этикетки товара)
  productBarcodeOzon String? @map("product_barcode_ozon")

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
}

enum OrderStatus {
  NEW
  IN_PROGRESS
  SHIPPED
  READY_FOR_PICKUP // товар в ПВЗ, ждёт клиента (WB: ready_for_pickup, waiting)
  DELIVERED // получен клиентом (WB: sold, receive, delivered)
  CANCELLED
}

enum OrderCancellationKind {
  CANCELLATION
  REFUSAL
}

model OrderStatusEvent {
  id             String      @id @default(uuid())
  orderId        String      @map("order_id")
  status         OrderStatus
  rawStatus      String?     @map("raw_status")
  source         String      @default("sync")
  occurredAt     DateTime    @default(now()) @map("occurred_at")
  cancellationKind OrderCancellationKind? @map("cancellation_kind")
  metadata       Json?

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, occurredAt])
  @@map("order_status_event")
}

model SalesSource {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  name      String
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([userId])
}

model WbSupply {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  wbSupplyId  String   @map("wb_supply_id")
  status      String   @default("ACTIVE") @map("status")
  warehouseId String?  @map("warehouse_id")
  name        String?  @map("name")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, wbSupplyId])
}

model Subscription {
  id         String           @id @default(uuid())
  userId     String           @unique @map("user_id")
  plan       SubscriptionPlan @default(FREE)
  externalId String?          @map("external_id")
  expiresAt  DateTime?        @map("expires_at")
  createdAt  DateTime         @default(now()) @map("created_at")
  updatedAt  DateTime         @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum SubscriptionPlan {
  FREE
  PROFESSIONAL
  BUSINESS
}

model Payment {
  id             String        @id @default(uuid())
  userId         String        @map("user_id")
  amount         Decimal       @db.Decimal(10, 2)
  currency       String        @default("RUB")
  status         PaymentStatus @default(PENDING)
  subjectType    String        @map("subject_type")
  subjectId      String        @map("subject_id")
  vtbOrderId     String?       @unique @map("vtb_order_id")
  paymentMethod  String?       @map("payment_method")
  refundable     Boolean       @default(true)
  refundedAmount Decimal       @default(0) @map("refunded_amount") @db.Decimal(10, 2)
  idempotencyKey String?       @unique @map("idempotency_key")
  metadata       Json?
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  user     User         @relation(fields: [userId], references: [id])
  webhooks VtbWebhook[]

  @@index([userId])
  @@index([status])
  @@index([vtbOrderId])
  @@index([subjectType, subjectId])
  @@index([createdAt])
}

enum PaymentStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
  REFUNDED
  CANCELLED
}

/// Справочник цветов WB (синхронизируется из API /content/v2/directory/colors).
/// Используется для выпадающего списка при выборе цвета товара.
model WbColor {
  id        Int      @id
  name      String   @db.VarChar(200)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("wb_color")
}

/// WB предметы (категории второго уровня).
/// Кешируются глобально — одна таблица на всех пользователей.
/// Обновляются автоматически при запросе (TTL 30 дней) и раз в месяц по Cron.
model WbSubject {
  id        Int      @id            // WB subjectID
  name      String   @db.VarChar(300)
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("wb_subject")
}

model VtbWebhook {
  id              String   @id @default(uuid())
  paymentId       String?  @map("payment_id")
  eventType       String   @map("event_type")
  vtbOrderId      String?  @map("vtb_order_id")
  payload         Json
  signature       String?  @db.VarChar(512)
  ipAddress       String?  @map("ip_address") @db.VarChar(45)
  processed       Boolean  @default(false)
  processingError String?  @map("processing_error") @db.Text
  createdAt       DateTime @default(now()) @map("created_at")

  payment Payment? @relation(fields: [paymentId], references: [id])

  @@index([vtbOrderId])
  @@index([processed])
  @@index([createdAt])
}

// ── AI Assistant ──────────────────────────────────────────────────────

model AssistantKnowledge {
  id        String   @id @default(uuid())
  sourceUrl String?  @map("source_url") @db.VarChar(1024)
  title     String   @db.VarChar(500)
  content   String   @db.Text
  category  String?  @db.VarChar(100)
  hash      String   @unique @db.VarChar(64)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([category])
  @@index([isActive])
  @@map("assistant_knowledge")
}

model AssistantConversation {
  id        String   @id @default(uuid())
  sessionId String   @map("session_id") @db.VarChar(128)
  ipAddress String?  @map("ip_address") @db.VarChar(45)
  userAgent String?  @map("user_agent") @db.Text
  status    String   @default("active") @db.VarChar(30)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  messages AssistantMessage[]

  @@index([sessionId])
  @@map("assistant_conversation")
}

model AssistantMessage {
  id             String   @id @default(uuid())
  conversationId String   @map("conversation_id")
  role           String   @db.VarChar(20)
  content        String   @db.Text
  confidence     Float?
  tokensUsed     Int?     @map("tokens_used")
  createdAt      DateTime @default(now()) @map("created_at")

  conversation AssistantConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([createdAt])
  @@map("assistant_message")
}

model AssistantUnanswered {
  id        String   @id @default(uuid())
  question  String   @db.Text
  sessionId String?  @map("session_id") @db.VarChar(128)
  answer    String?  @db.Text
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([resolved])
  @@index([createdAt])
  @@map("assistant_unanswered")
}

model AssistantOperator {
  id        String   @id @default(uuid())
  chatId    String   @map("chat_id") @db.VarChar(32)
  type      String   @default("primary") @db.VarChar(30)
  title     String?  @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([chatId])
  @@map("assistant_operator")
}
