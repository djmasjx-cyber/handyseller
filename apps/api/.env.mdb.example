# Использовать при подключении к Yandex Managed PostgreSQL через туннель
# 1. Запустите туннель: ./scripts/db-tunnel-mdb.sh (в отдельном терминале)
# 2. Скопируйте: cp .env.mdb.example .env.mdb
# 3. Подставьте пароль из .env.secrets (YANDEX_MDB_PASSWORD)
# 4. Используйте: cp .env.mdb .env  или  export $(cat .env.mdb | xargs) && npm run dev

DATABASE_URL=postgresql://handyseller_user:YOUR_MDB_PASSWORD@localhost:5434/handyseller?sslmode=require
