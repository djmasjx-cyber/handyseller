{
  "name": "api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "dev": "nest start --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:unit": "jest --testPathIgnorePatterns='e2e|integration'",
    "test:integration": "jest --testPathPattern=integration",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:load": "artillery run test/artillery/load.yml",
    "test:load:quick": "artillery quick --count 100 --num 10 http://localhost:4000/health",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate-pii": "node scripts/migrate-encrypt-pii.js",
    "prisma:studio": "prisma studio",
    "prisma:seed": "node scripts/seed-database.js",
    "debug:wb-order": "ts-node scripts/debug-wb-order-sync.ts"
  },
  "prisma": {
    "seed": "node scripts/seed-database.js"
  },
