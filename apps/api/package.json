    "@sentry/node": "^8.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@willsoto/nestjs-prometheus": "^6.0.0",
    "@yandex-cloud/nodejs-sdk": "2.8.0",
    "axios": "^1.13.5",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.69.2",
