12:["$","section",null,{"className":"mb-12","children":["$","div",null,{"className":"prose prose-lg max-w-none text-muted-foreground","children":[["$","p",null,{"children":"Качественное фото — это 80% успеха карточки товара. Покупатель не может потрогать изделие, поэтому решение о покупке принимает по картинке. Хорошая новость: для хороших фото не нужна дорогая камера или студия."}],["$","p",null,{"children":"В этом гайде покажем, как сделать продающие фото хендмейда на обычный смартфон. Всё, что нужно — правильный свет, фон и немного практики."}]]}]}]
