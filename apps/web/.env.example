# URL NestJS API (для проксирования register/login)
# На VM с полным деплоем: http://localhost:4000
# С отдельным API: https://api.example.com
API_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=

# Яндекс.Метрика - номер счётчика из metrika.yandex.ru
NEXT_PUBLIC_YANDEX_METRIKA_ID=107695847

# DaData — подсказки адреса (TMS). Только сервер: apps/web/app/api/address-suggest/route.ts
# Не используйте NEXT_PUBLIC_* — ключ не должен попадать в бандл браузера.
# Локально: скопируйте в apps/web/.env.local (файл в .gitignore).
DADATA_TOKEN=
# или DADATA_API_KEY=  — тот же API-ключ из кабинета DaData
# при необходимости (тариф / тип ключа):
# DADATA_SECRET=
