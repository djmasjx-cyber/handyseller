# Скопировать в ~/.ssh/config на Mac (или: cat scripts/ssh-handyseller.config >> ~/.ssh/config)
# Затем: ssh handyseller-vm
# Нужен ключ ~/.ssh/yandex_vm (или поменяйте IdentityFile)

Host handyseller-vm
    HostName 51.250.119.224
    User ubuntu
    IdentityFile ~/.ssh/yandex_vm
    IdentitiesOnly yes
