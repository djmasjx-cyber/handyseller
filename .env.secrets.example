# Учётные данные администратора (для seed и деплоя)
# Скопируйте в .env.secrets и заполните реальными значениями.
# .env.secrets в .gitignore — НЕ коммитить!
# Пароль с ; и др. спецсимволами — в кавычках.

ADMIN_EMAIL=your-admin@example.com
ADMIN_PASSWORD="your-secure-password"

# === Подключение к VM и БД (для scripts/db-tunnel.sh, connect-db.sh) ===
# VM_HOST=158.160.209.158
# DEPLOY_SSH_KEY=$HOME/.ssh/yandex_vm
# POSTGRES_PASSWORD=handyseller_prod_change_me
# DB_LOCAL_PORT=5433

# === Yandex Managed PostgreSQL (опционально, вместо Docker на VM) ===
# Хост: terraform output postgresql_host из infra/terraform
# VM должна быть в той же VPC, что и кластер (или иметь доступ к нему)
# YANDEX_MDB_HOST=rc1a-xxxxx.mdb.yandexcloud.net
# YANDEX_MDB_PASSWORD=пароль_из_terraform_tfvars
# YANDEX_MDB_USER=handyseller_user
# DB_MDB_LOCAL_PORT=5434   # порт для туннеля к Managed DB (по умолчанию 5434)

# CORS — для работы через домен (вход, API). Деплой по умолчанию добавляет app.handyseller.ru
# CORS_ORIGIN=https://app.handyseller.ru,http://app.handyseller.ru,https://handyseller.ru

# Tilda — доступы для лендинга (handyseller.ru)
# TILDA_EMAIL=your@email.com
# TILDA_PASSWORD=your-password

# Email — коды подтверждения при регистрации (обязательно в production)
# Вариант 1: Resend (проще — один ключ, 100 писем/день бесплатно)
# Зарегистрироваться: https://resend.com → API Keys → создать ключ
RESEND_API_KEY=re_xxxxxxxxxxxx
# Вариант 2: SMTP (Yandex, Mail.ru, Gmail)
# SMTP_HOST=smtp.yandex.ru
# SMTP_PORT=587
# SMTP_USER=noreply@handyseller.ru
# SMTP_PASS=your-password
# EMAIL_FROM="HandySeller <noreply@handyseller.ru>"

# DaData — подсказки адреса на сайте (контейнер web). Не коммитить реальные значения.
# На VM добавьте в /opt/handyseller/.env.production или .env.extra (подмешивается при деплое):
# DADATA_TOKEN=ваш_api_ключ
# DADATA_SECRET=ваш_секретный_ключ

# ВТБ Эквайринг — нужны для кнопки «Оплатить». Без них: «Оплата недоступна».
# Получить: https://www.vtb.ru/business/platezhi/acquiring/
# VTB_USER_NAME=логин_из_ЛК_ВТБ
# VTB_PASSWORD=пароль
# VTB_MODE=sandbox   # sandbox=тест, production=боевой
# VTB_WEBHOOK_SECRET=   # опционально
